# Copy to .env.local for local dev. Set these on Vercel for production.

# Neon Postgres (via Vercel Marketplace → installs DATABASE_URL automatically)
DATABASE_URL=

# Resend (for contact form lead notifications)
RESEND_API_KEY=
RESEND_FROM="Crowned Code <noreply@crownedcode.com>"
LEADS_NOTIFY_TO="team@crownedcode.com"

# PostHog (analytics — optional; site works without it)
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
